								"register"
							]
						},
						"description": "Register a new user account on TaskFlow Pro."
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const response = pm.response.json();",
									"if (response.status === 'success' && response.token) {",
									"    pm.collectionVariables.set('token', response.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					]
