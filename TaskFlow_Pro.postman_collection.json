				{
					"name": "Create Task",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Postman Collection Task\",\n  \"description\": \"Generate and verify a complete Postman collection for the backend services.\",\n  \"priority\": \"High\",\n  \"status\": \"Pending\",\n  \"dueDate\": \"2026-07-15\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/tasks",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"tasks"
							]
						},
						"description": "Create a new task."
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const response = pm.response.json();",
									"if (response.status === 'success' && response.data && response.data.task) {",
									"    const taskId = response.data.task._id || response.data.task.id;",
									"    pm.collectionVariables.set('taskId', taskId);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					]
				},
